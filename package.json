{
  "name": "@m1kapp/maging",
  "version": "0.1.16",
  "description": "LLM-native UI primitives. Dashboard? Deck? Doc? Just mage it.",
  "license": "MIT",
  "type": "module",
  "main": "dist/maging.js",
  "style": "dist/maging.css",
  "files": [
    "dist/**",
    "llms.txt",
    "llms-dashboard.txt",
    "llms-landing.txt",
    "llms-weekly-report.txt",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "llm",
    "dashboard",
    "ai",
    "claude",
    "chatgpt",
    "gemini",
    "widgets",
    "html",
    "echarts",
    "tailwind",
    "prompt-to-ui"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:tw": "tailwindcss -i weekly-report/tw-input.css -o weekly-report/tw.css --content weekly-report/index.html --minify && tailwindcss -i weekly-report/tw-input.css -o landing/tw.css --content landing/startup.html --minify",
    "build:llms": "node scripts/build-llms.mjs",
    "sync": "node scripts/sync-index.mjs",
    "count-tokens": "node scripts/count-prompt-tokens.mjs",
    "vercel-build": "vite build"
  },
  "devDependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@tailwindcss/cli": "^4.2.4",
    "gpt-tokenizer": "^2.9.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10"
  }
}
